{
    "name": "ip_filter dev environment",

    "build": {
        "dockerfile": "../docker/Dockerfile",
        "context": ".."
    },

    "workspaceFolder": "/app",

    "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind",

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools"
            ]
        }
    }
}